# Aevia - 环境变量配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# 阿里云百炼 API Key（必填）
# 获取：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# 角色配置（可选）
AEVIA_CHARACTER_NAME=小柔

# 参考图配置（可选，默认使用 assets/default-character.png）
# AEVIA_REFERENCE_IMAGE_URL=/path/to/custom-character.png
AEVIA_REFERENCE_MODEL=z-image-turbo
AEVIA_DEFAULT_IMAGE_MODEL=wan2.6-image
